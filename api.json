      },

      "delete": {
        "method": "DELETE",
        "path": "/bongolava_job/admin/messages/{id}",
        "auth_required": true,
        "roles": ["admin"],
        "response_200": { "message": "Message deleted successfully." }
      }
    },

    "admin_jobs": {
      "description": "Admin job moderation",

      "pending": {
        "method": "GET",
