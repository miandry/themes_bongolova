{
  "info": {
    "title": "Bongolava Jobs API",
    "version": "1.0.0",
    "description": "All JSON endpoints served by the bongolava_job Drupal module. Base URL: /bongolava_job. Authentication uses Bearer tokens (Authorization: Bearer <token>). All request bodies are JSON unless noted as multipart/form-data.",
    "base_url": "/bongolava_job",
    "auth_header": "Authorization: Bearer <token>"
  },

  "endpoints": {

    "auth": {
      "description": "Authentication — login, logout, current user, registration",

      "login": {
        "method": "POST",
        "path": "/bongolava_job/login",
        "auth_required": false,
        "used_by": ["LoginView.vue"],
        "request": {
          "Content-Type": "application/json",
          "body": {
            "email": "string (required) — user email address",
            "password": "string (required) — plain-text password"
          }
        },
        "response_200": {
          "user": {
            "id": 1,
            "email": "admin@bongolavajobs.mg",
            "name": "admin@bongolavajobs.mg",
            "created_at": "2026-01-01T00:00:00+00:00"
          },
          "token": "eyJ0eXAiOiJKV1QiLCJhbGciOiJIUzI1NiJ9...",
          "role": "candidate | recruiter | admin",
          "profile": {
            "id": 1,
            "user_id": 1,
            "first_name": "Sarah",
            "last_name": "Rakoto",
            "job_target": "Ingénieure Agronome",
            "location": "Tsiroanomandidy",
            "skills": ["Agriculture", "Irrigation"],
            "experience": "5 ans",
            "bio": "...",
            "phone": "+261 34 56 78 90",
            "photo_url": null,
            "cv_url": null,
            "available": true,
            "created_at": "2026-01-15T00:00:00+00:00"
          }
        },
        "response_401": {
          "message": "The given data was invalid.",
          "errors": {
            "email": ["These credentials do not match our records."]
          }
        },
        "response_422": {
          "message": "The given data was invalid.",
          "errors": {
            "email": ["The email field is required."],
            "password": ["The password field is required."]
          }
        }
      },

      "logout": {
        "method": "POST",
        "path": "/bongolava_job/logout",
        "auth_required": true,
        "request": { "body": {} },
        "response_200": {
          "message": "Logged out successfully."
        }
      },

      "me": {
        "method": "GET",
        "path": "/bongolava_job/me",
        "auth_required": true,
        "used_by": ["App.vue — session restore on page load"],
        "response_200": {
          "user": { "id": 1, "email": "admin@bongolavajobs.mg", "name": "admin@bongolavajobs.mg" },
          "role": "candidate | recruiter | admin",
          "profile": "same shape as login.profile (candidate or recruiter)"
        }
      },

      "register_candidate": {
        "method": "POST",
        "path": "/bongolava_job/register/candidate",
        "auth_required": false,
        "used_by": ["RegisterView.vue (role=candidat)"],
        "request": {
          "Content-Type": "application/json",
          "body": {
            "email": "string (required)",
            "password": "string (required, min 8 chars)",
            "first_name": "string (required)",
            "last_name": "string (required)",
            "phone": "string (optional)"
          }
        },
        "response_200": "same shape as login response (user + token + role + profile)"
      },

      "register_recruiter": {
        "method": "POST",
        "path": "/bongolava_job/register/recruiter",
        "auth_required": false,
        "used_by": ["RegisterView.vue (role=recruteur)"],
        "request": {
          "Content-Type": "application/json",
          "body": {
            "email": "string (required)",
            "password": "string (required, min 8 chars)",
            "organization": "string (required) — company name",
            "phone": "string (optional)"
          }
        },
        "response_200": "same shape as login response (user + token + role + profile)"
      }
    },

    "jobs": {
      "description": "Job offers — public listing, detail, recruiter CRUD",

      "list": {
        "method": "GET",
        "path": "/bongolava_job/jobs",
        "auth_required": false,
        "used_by": ["JobsView.vue", "FeaturedJobsSection.vue", "HomeView.vue (drupalSettings.bongolavaJobs)"],
        "query_params": {
          "search": "string — full-text search on title and tags",
          "sector": "agriculture | tourisme | industrie | education | informatique | transport | services",
          "type": "CDI | CDD | Stage | Freelance",
          "location": "Tsiroanomandidy | Maintirano | Bongolava | Télé-travail",
          "sort": "pertinence | recent | salary",
          "page": "integer (default: 1)",
          "per_page": "integer (default: configured in module)"
        },
        "response_200_without_page": [
          {
            "id": 1,
            "title": "Ingénieur Agronome",
            "company": "Ferme de Bongolava",
            "location": "Tsiroanomandidy",
            "type": "CDI",
            "salary": "1 200 000 Ar",
            "urgent": true,
            "remote": false,
            "sector": "agriculture",
            "tags": ["Agriculture", "Élevage"],
            "created_at": "2026-01-15T00:00:00+00:00",
            "expires_at": "2026-02-15T00:00:00+00:00",
            "recruiter_id": 1,
            "recruiter_name": "Ferme de Bongolava",
            "recruiter_logo_url": null
          }
        ],
        "response_200_with_page": {
          "data": "array of job objects",
          "total": 42,
          "per_page": 10,
          "current_page": 1,
          "last_page": 5
        }
      },

      "get": {
        "method": "GET",
        "path": "/bongolava_job/jobs/{id}",
        "auth_required": false,
        "used_by": ["JobDetailView.vue"],
        "response_200": {
          "id": 1,
          "title": "Ingénieur Agronome",
          "company": "Ferme de Bongolava",
          "location": "Tsiroanomandidy",
          "type": "CDI",
          "salary": "1 200 000 Ar",
          "urgent": true,
          "remote": false,
          "sector": "agriculture",
          "description": "Full description text...",
          "responsibilities": ["Superviser les opérations...", "Optimiser les rendements..."],
          "requirements": ["Diplôme en agronomie...", "Minimum 3 ans d'expérience..."],
          "tags": ["Agriculture", "Élevage", "Durable"],
          "created_at": "2026-01-15T00:00:00+00:00",
          "expires_at": "2026-02-15T00:00:00+00:00",
          "recruiter": {
            "id": 1,
            "name": "Jean Rakoto",
            "organization": "Ferme de Bongolava",
            "email": "recrutement@fermebongolava.mg",
            "phone": "+261 34 12 345 67",
            "logo_url": null
          }
        },
        "response_404": { "message": "Not Found." }
      },

      "create": {
        "method": "POST",
        "path": "/bongolava_job/jobs",
        "auth_required": true,
        "roles": ["recruiter"],
        "request": {
          "Content-Type": "application/json",
          "body": {
            "title": "string (required)",
            "description": "string (required)",
            "location": "string (required)",
            "type": "CDI | CDD | Stage | Freelance (optional)",
            "salary": "string (optional) — e.g. '1 200 000 Ar'",
            "sector": "string (optional)",
            "tags": "array of strings (optional)",
            "urgent": "boolean (optional, default false)",
            "remote": "boolean (optional, default false)",
            "responsibilities": "array of strings (optional)",
            "requirements": "array of strings (optional)",
            "contact_email": "string (optional, defaults to authenticated user email)",
            "expires_at": "ISO 8601 date string (optional)"
          }
        },
        "response_201": "job object (same shape as get)"
      },

      "update": {
        "method": "PUT",
        "path": "/bongolava_job/jobs/{id}",
        "auth_required": true,
        "roles": ["recruiter (owner only)"],
        "request": {
          "Content-Type": "application/json",
          "body": "any subset of create fields"
        },
        "response_200": "updated job object"
      },

      "delete": {
        "method": "DELETE",
        "path": "/bongolava_job/jobs/{id}",
        "auth_required": true,
        "roles": ["recruiter (owner only)"],
        "response_200": { "message": "Job deleted successfully." }
      },

      "my_jobs": {
        "method": "GET",
        "path": "/bongolava_job/my-jobs",
        "auth_required": true,
        "roles": ["recruiter"],
        "response_200": "array of job objects belonging to authenticated recruiter"
      }
    },

